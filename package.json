/* Mobile Menu Toggle */
(function() {
    // We use a function wrapper to prevent conflicts with other scripts
    document.addEventListener('DOMContentLoaded', function() {
        
        // 1. Find the elements
        var toggleButton = document.querySelector('.mobile-menu-toggle');
        var navMenu = document.querySelector('.nav-menu');

        // 2. Check if they exist before doing anything
        if (toggleButton && navMenu) {
            
            toggleButton.addEventListener('click', function(event) {
                // Prevent the page from jumping or reloading
                event.preventDefault();
                
                // Toggle the 'active' class
                navMenu.classList.toggle('active');
                
                // Change the button look (optional)
                toggleButton.classList.toggle('is-open');
                
                // Accessibility
                var expanded = navMenu.classList.contains('active');
                toggleButton.setAttribute('aria-expanded', expanded);
            });

            // 3. Close the menu if a link inside it is clicked
            navMenu.addEventListener('click', function(event) {
                if (event.target.tagName === 'A') {
                    navMenu.classList.remove('active');
                    toggleButton.classList.remove('is-open');
                }
            });
        }
    });
})();
